{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vektas",
  "compatibility_date": "2026-07-16",
  "main": "./worker/index.ts",
  "preview_urls": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
